BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Joy World Cityfuns WMS
FE_WMS_APP_URL=http://app.wms.localhost
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY= (Chưa có)
BREVO_EMAIL_SIGNATURE_HTML=
BREVO_EMAIL_SIGNATURE_TEXT=
EXTERNAL_QUEUE_AUTO_SUBMIT_TIMES=14:00,22:00
EXTERNAL_QUEUE_AUTO_SUBMIT_CRON_SECRET=
EXTERNAL_QUEUE_AUTO_SUBMIT_WORKER_ENABLED=false
CITYFUNS_API_BASE_URL=https://cityfuns.joyworld.vn/api/v1
INTERNAL_API_KEY=
# API abuse protection. Production defaults to one trusted reverse-proxy hop.
BE_WMS_TRUST_PROXY_HOPS=1
BE_WMS_RATE_LIMIT_WINDOW_MS=60000
BE_WMS_RATE_LIMIT_MAX_REQUESTS=300
BE_WMS_AUTH_RATE_LIMIT_WINDOW_MS=900000
BE_WMS_AUTH_RATE_LIMIT_MAX_REQUESTS=30
# Development-only local integration bypass. All four guards are required.
ALLOW_LOCAL_INTEGRATION_BYPASS=false
LOCAL_INTEGRATION_API_KEY=
# Only required when running apps/be-wms/src/scripts/seed-ecom-client.ts.
LOCAL_INTEGRATION_API_SECRET=
LOCAL_INTEGRATION_ALLOWED_WAREHOUSE_IDS=
# Required by be-wms to encrypt saved OpenAPI SecretKey values.
OPENAPI_CONFIG_ENCRYPTION_KEY=
# Authorization rollout: SHADOW serves live RBAC and logs differences;
# MATERIALIZED serves only the active user_access snapshot and fails closed.
FACILITY_AUTHORIZATION_MODE=MATERIALIZED
