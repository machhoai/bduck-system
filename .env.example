# ================================================================
#  BDuck System — Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env files to version control.
# ================================================================


# ================================================================
# === GENERAL ===
# ================================================================

NODE_ENV=development

# ================================================================
# === WMS BACKEND (be-wms) ===
# ================================================================

BE_WMS_PORT=4000
BE_WMS_CORS_ORIGIN=http://app.wms.localhost,http://localhost:3000

# ================================================================
# === WMS FRONTEND (fe-wms) ===
# ================================================================

FE_WMS_PORT=3000
NEXT_PUBLIC_API_URL=http://api.wms.localhost


# ================================================================
# === TEST ENVIRONMENT — Firebase Project #1 ===
# ================================================================

# Firebase Admin SDK (Server-side)
TEST_FIREBASE_PROJECT_ID=bduck-wms-test
TEST_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@bduck-wms-test.iam.gserviceaccount.com
TEST_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_TEST_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Client SDK (Client-side / NEXT_PUBLIC_*)
TEST_NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy-your-test-api-key
TEST_NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=bduck-wms-test.firebaseapp.com
TEST_NEXT_PUBLIC_FIREBASE_PROJECT_ID=bduck-wms-test
TEST_NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=bduck-wms-test.appspot.com
TEST_NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
TEST_NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx

# Test Server Deployment
TEST_SERVER_HOST=0.0.0.0
TEST_SERVER_USER=deploy
TEST_SERVER_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# Firebase Admin SDK — Base64-encoded Service Account JSON
# ► Cách tạo: cat service-account.json | base64 -w 0
# ► Dùng thay cho file JSON thực tế để tránh commit credentials.
TEST_FIREBASE_SERVICE_ACCOUNT_BASE64=ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsCiAgLi4uCn0=


# ================================================================
# === PRODUCTION ENVIRONMENT — Firebase Project #2 ===
# ================================================================

# Firebase Admin SDK (Server-side)
PROD_FIREBASE_PROJECT_ID=bduck-wms-prod
PROD_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@bduck-wms-prod.iam.gserviceaccount.com
PROD_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PROD_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Client SDK (Client-side / NEXT_PUBLIC_*)
PROD_NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyCburpfs59zWlp3KFzgFwePNqP1OT883lI"
PROD_NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="jw-system-f2104.firebaseapp.com"
PROD_NEXT_PUBLIC_FIREBASE_PROJECT_ID="jw-system-f2104"
PROD_NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="jw-system-f2104.firebasestorage.app"
PROD_NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="107789134874"
PROD_NEXT_PUBLIC_FIREBASE_APP_ID="1:107789134874:web:eaf2ef659a0e02168b75a3"

# Production Server Deployment
PROD_SERVER_HOST=0.0.0.0
PROD_SERVER_USER=deploy
PROD_SERVER_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# Firebase Admin SDK — Base64-encoded Service Account JSON
PROD_FIREBASE_SERVICE_ACCOUNT_BASE64=ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsCiAgLi4uCn0=


# ================================================================
# === ACTIVE RUNTIME VARIABLES (Copy from TEST or PROD above) ===
# ================================================================
# Các biến bên dưới là biến THỰC SỰ được code đọc tại runtime.
# CI/CD pipeline sẽ copy giá trị từ TEST_* hoặc PROD_* vào đây
# tùy theo môi trường triển khai.

# --- Backend (be-wms) ---
FIREBASE_SERVICE_ACCOUNT_BASE64=ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsCiAgLi4uCn0=

# --- Frontend (fe-wms) — Public keys, an toàn khi expose ---
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy-your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx
