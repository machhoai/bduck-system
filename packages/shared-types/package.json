{
  "name": "@bduck/shared-types",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts"
  },
  "devDependencies": {
    "@bduck/eslint-config": "workspace:*",
    "@bduck/tsconfig": "workspace:*",
    "eslint": "^8.57.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
