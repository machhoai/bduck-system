rules_version = '2';

/**
 * Firestore Security Rules — BDuck WMS
 *
 * ► Nguyên tắc: Authenticated users mới được đọc/ghi.
 * ► Write operations chính nên đi qua BE (Admin SDK) để đảm bảo RBAC.
 * ► Client SDK chỉ cần READ cho realtime listeners (onSnapshot).
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Product Categories: Authenticated users can read ──
    match /product_categories/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Write only via Admin SDK (BE)
    }

    // ── Products: Authenticated users can read ──
    match /products/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Organizations: Authenticated users can read for warehouse selector ──
    match /organizations/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Warehouses: Authenticated users can read ──
    match /warehouses/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Warehouse Locations: Authenticated users can read ──
    match /warehouse_locations/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /warehouse_location_slots/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /warehouse_location_slot_products/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Users: Authenticated users can read (for user lists, approver pickers) ──
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /employee_profiles/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Roles: Authenticated users can read (for RBAC) ──
    match /roles/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── User Warehouse Roles: Authenticated users can read own ──
    match /user_warehouse_roles/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Audit Logs: Authenticated read (for admin audit trail) ──
    match /audit_logs/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Product BOM: Authenticated read ──
    match /product_bom/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Vouchers (Import/Export/Transfer): Authenticated read ──
    match /vouchers/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Inventory: Authenticated read ──
    match /inventory/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /inventory_stock_policies/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /warehouse_attendance_policies/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /warehouse_attendance_exemptions/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /attendance_logs/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Workflow Definitions: Authenticated read (+ versions subcollection) ──
    match /workflow_definitions/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /versions/{versionId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ── Workflow Instances: Authenticated read (+ tasks subcollection) ──
    match /workflow_instances/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /tasks/{taskId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ── CollectionGroup: tasks (required for collectionGroup queries) ──
    // collectionGroup("tasks") bypasses nested match rules above.
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Import Vouchers: Authenticated read (+ items subcollection) ──
    match /import_vouchers/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ── Export Vouchers: Authenticated read (+ items subcollection) ──
    match /export_vouchers/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ── Transfer Orders: Authenticated read (+ items subcollection) ──
    match /transfer_orders/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ── In-App Notifications: Read own + mark as read ──
    match /in_app_notifications/{docId} {
      allow read: if isAuthenticated();
      // Allow user to mark own notifications as read
      allow update: if isAuthenticated()
        && resource.data.target_user_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);
      allow create, delete: if false;
    }

    // ── Notification Dispatches: Authenticated read, write only via BE ──
    match /notification_dispatches/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Nonconformity Reports: Authenticated read ──
    match /nonconformity_reports/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Pending Approvals: Authenticated read (for TaskInbox realtime) ──
    match /pending_approvals/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Write only via Admin SDK (BE)
    }

    // ── Process Configs: Authenticated read (for admin config page) ──
    match /process_configs/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Expenses: Authenticated read (for expense dashboard realtime) ──
    match /expenses/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Revenue Sync: Authenticated read (for dashboard revenue overlay) ──
    match /revenue_sync/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Revenue Dashboard: Authenticated read for realtime cached JoyWorld dashboards ──
    match /revenue_dashboards/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /orders/{orderId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }

      match /sold_items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ── Default: Deny all ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
