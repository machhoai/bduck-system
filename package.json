{
    "name": "@bduck/root",
    "version": "1.0.0",
    "private": true,
    "description": "BDuck System — Monorepo for HR and WMS applications",
    "packageManager": "pnpm@9.15.4",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "--- DEV ---": "",
        "dev": "pnpm run --parallel --filter @bduck/fe-wms --filter @bduck/be-wms dev",
        "dev:wms": "pnpm run --parallel --filter @bduck/fe-wms --filter @bduck/be-wms dev",
        "dev:fe-wms": "pnpm --filter @bduck/fe-wms dev",
        "dev:be-wms": "pnpm --filter @bduck/be-wms dev",
        "dev:be-hr": "pnpm --filter @bduck/be-hr dev",
        "--- BUILD ---": "",
        "build": "pnpm run --recursive build",
        "build:fe-wms": "pnpm --filter @bduck/fe-wms build",
        "build:be-wms": "pnpm --filter @bduck/be-wms build",
        "build:be-hr": "pnpm --filter @bduck/be-hr build",
        "--- QUALITY ---": "",
        "lint": "pnpm run --recursive lint",
        "lint:fix": "pnpm run --recursive lint:fix",
        "typecheck": "pnpm run --recursive typecheck",
        "security:audit": "node scripts/audit-facility-access.mjs --enforce --summary",
        "security:audit:report": "node scripts/audit-facility-access.mjs",
        "security:audit:summary": "node scripts/audit-facility-access.mjs --summary",
        "security:audit:enforce": "node scripts/audit-facility-access.mjs --enforce --summary",
        "test:access-matrix": "node scripts/validate-facility-access-matrix.mjs",
        "test:firestore-rules": "firebase emulators:exec --only firestore --project bduck-rules-test \"node --test apps/fe-wms/src/security/firestoreRules.test.mjs\"",
        "test:access-session": "pnpm --filter @bduck/be-wms exec tsx --test ../fe-wms/src/security/accessSession.test.ts",
        "test:facility-partition": "pnpm test:authorization && pnpm test:access-matrix && pnpm test:access-session && pnpm test:firestore-rules",
        "test:facility-access-planner": "pnpm --filter @bduck/be-wms test:facility-access-planner",
        "test:authorization": "pnpm --filter @bduck/be-wms test:authorization",
        "test:identity-security": "pnpm --filter @bduck/be-wms test:identity-security",
        "test:scoped-query": "pnpm --filter @bduck/be-wms test:scoped-query",
        "test:security-foundation": "pnpm --filter @bduck/be-wms test:security-foundation",
        "migrate:facility-access": "pnpm --filter @bduck/be-wms migrate:facility-access",
        "rebuild:user-access": "pnpm --filter @bduck/be-wms rebuild:user-access",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
        "--- DOCKER (Production) ---": "",
        "docker:wms:up": "docker compose --env-file .env.local up -d --build",
        "docker:wms:down": "docker compose --env-file .env.local down",
        "docker:wms:logs": "docker compose --env-file .env.local logs -f",
        "--- DOCKER (Dev - Live Reload) ---": "",
        "docker:dev:up": "docker compose -f docker-compose.dev.yml up -d --build",
        "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
        "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
        "docker:dev:rebuild": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d --build",
        "--- GIT HOOKS ---": "",
        "prepare": "husky",
        "--- GCP CLOUD RUN ---": "",
        "gcp:build:be-wms": "gcloud builds submit --config cloudbuild.yaml --project jw-system-f2104",
        "gcp:deploy:be-wms": "gcloud run deploy be-wms --image asia-southeast1-docker.pkg.dev/jw-system-f2104/cloud-run-source-deploy/be-wms:latest --region asia-southeast1 --project jw-system-f2104 --allow-unauthenticated",
        "deploy:be-wms": "pnpm run gcp:build:be-wms && pnpm run gcp:deploy:be-wms"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "husky": "^9.1.0",
        "lint-staged": "^15.2.0",
        "prettier": "^3.4.0",
        "typescript": "^5.7.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css,yml,yaml}": [
            "prettier --write"
        ]
    }
}
