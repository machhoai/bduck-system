# ==============================================================================
# Backend Development Dockerfile (Hot Reload)
# ==============================================================================
# This Dockerfile installs dependencies once, then relies on volume mounts
# from docker-compose.dev.yml to provide source code for live editing.
# ==============================================================================

FROM node:22-alpine

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

# Copy workspace root files needed for pnpm install
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./

# Copy package.json files for the target app AND its workspace dependencies
COPY apps/be-wms/package.json ./apps/be-wms/
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/tsconfig/package.json ./packages/tsconfig/
COPY packages/eslint-config/package.json ./packages/eslint-config/

# Install ALL dependencies (including devDependencies for tsx watch)
RUN pnpm install --frozen-lockfile

# Copy full source (will be overridden by volume mounts for src/)
COPY packages/ ./packages/
COPY apps/be-wms/ ./apps/be-wms/

WORKDIR /app/apps/be-wms

EXPOSE 4000

# Run tsx watch for auto-reload on file changes
CMD ["pnpm", "dev"]
