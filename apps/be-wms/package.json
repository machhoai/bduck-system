{
  "name": "@bduck/be-wms",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test:facility-access-planner": "tsx --test src/scripts/facilityAccessBackfillPlanner.test.ts src/scripts/facilityAccessBackfillProgress.test.ts src/repositories/userAccessVersionInvariant.test.ts src/services/userAccessMaterializationPlan.test.ts src/utils/officeScopePolicy.test.ts",
    "test:authorization": "tsx --test src/services/authorization/accessContextBuilder.identity.test.ts src/services/authorization/accessContextBuilder.malformed.test.ts src/services/authorization/accessContextBuilder.office.test.ts src/services/authorization/authorizationService.test.ts src/services/authorization/facilityPartitionEffectiveness.test.ts src/services/authorizationContextComparison.test.ts src/services/authorizationRolloutService.test.ts src/services/facilityRelationshipPolicy.test.ts src/services/transferReceivingItemPolicy.test.ts src/services/roleDelegationPolicy.test.ts src/services/userTargetPolicy.test.ts src/services/onlineSalesRequestPolicy.test.ts src/services/officeScopeAdministrationPolicy.test.ts src/services/officeScopeOverviewPolicy.test.ts src/services/officeScopeHistoryPolicy.test.ts src/services/officeScopeMaterializationPolicy.test.ts ../fe-wms/src/utils/officeScopeDraft.test.ts src/repositories/authorizationSourceLoader.test.ts src/api/middlewares/requestAccessContext.test.ts src/api/middlewares/rbacMiddleware.test.ts",
    "test:identity-security": "tsx --test src/services/roleAssignmentValidity.test.ts src/services/rolePermissionUtils.test.ts src/services/authAccessBootstrapService.test.ts src/services/authSessionFlow.test.ts src/api/middlewares/authIdentityMiddleware.test.ts src/api/middlewares/localIntegrationBypass.test.ts src/api/middlewares/rateLimitMiddleware.test.ts src/utils/secureSecret.test.ts src/utils/authSessionCookie.test.ts",
    "test:scoped-query": "tsx --test src/repositories/facilityScopedQuery.test.ts",
    "test:security-foundation": "pnpm run test:facility-access-planner && pnpm run test:authorization && pnpm run test:identity-security && pnpm run test:scoped-query",
    "migrate:facility-access": "tsx --env-file=../../.env.local src/scripts/backfillFacilityAccess.ts",
    "rebuild:user-access": "tsx --env-file=../../.env.local src/scripts/rebuildUserAccess.ts"
  },
  "dependencies": {
    "@bduck/shared-types": "workspace:*",
    "@google-cloud/tasks": "^6.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.3.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.0.0",
    "nodemailer": "^8.0.10",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@bduck/eslint-config": "workspace:*",
    "@bduck/tsconfig": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^11.0.0",
    "eslint": "^8.57.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
